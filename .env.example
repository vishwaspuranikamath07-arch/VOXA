# =========================
# ELEVENLABS TTS (PRIMARY - Round Robin)
# =========================
ELEVENLABS_API_KEYS=your_elevenlabs_key_1,your_elevenlabs_key_2

# =========================
# LLM KEY POOLS (Comma-separated, numbered style supported)
# =========================
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
OPENAI_API_KEYS=your_openai_key_1,your_openai_key_2

# =========================
# SARVAM AI (INDIAN LANG)
# =========================
SARVAM_API_KEY=your_sarvam_key
SARVAM_API_KEYS=your_sarvam_key_1,your_sarvam_key_2,your_sarvam_key_3
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_CHAT_URL=https://api.sarvam.ai/v1/chat
SARVAM_WS_URL=wss://api.sarvam.ai/text-to-speech/ws

# =========================
# PROVIDER SETTINGS
# =========================
PRIMARY_LLM_PROVIDER=gemini
PRIMARY_TTS_PROVIDER=elevenlabs
LLM_PROVIDER_TIMEOUT_MS=1500
TTS_PROVIDER_TIMEOUT_MS=3000
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_MODEL=gpt-4o-mini

# =========================
# KEY MANAGER SETTINGS
# =========================
KEY_RATE_LIMIT_COOLDOWN_SECONDS=60
KEY_MAX_FAIL_COUNT=3
KEY_RECOVERY_CHECK_INTERVAL_SECONDS=30

# =========================
# PERFORMANCE
# =========================
RESPONSE_CACHE_TTL_SECONDS=300
MAX_CONVERSATION_MEMORY_TURNS=10
SESSION_TTL_MINUTES=30

# =========================
# SERVER
# =========================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# =========================
# WHISPER (ASR)
# =========================
WHISPER_MODEL=small

# =========================
# REDIS (OPTIONAL)
# =========================
REDIS_URL=redis://localhost:6379
